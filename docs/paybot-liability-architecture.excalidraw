    },
    {
      "id": "phase1-content",
      "type": "text",
      "x": 80,
      "y": 400,
      "width": 280,
      "height": 200,
      "text": "Weeks 1-2 | Low Risk\n\n• audit.ts — event logging\n• Flagging rules engine\n  - Amount > threshold\n  - Repeated payee\n  - Velocity spike\n  - New payee\n• Review queue API\n• Signed payment receipts\n• PaymentRequest.context\n\nNew files: audit.ts,\ntypes-liability.ts",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 112,
      "version": 1,
      "isDeleted": false,
      "boundElements": null,
      "link": null,
      "locked": false,
      "groupIds": ["proposed-flow"]
    },
