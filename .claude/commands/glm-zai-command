#!/bin/bash
# GLM Integration via ZAI API - Custom Command for AIOS

set -e

# Configuration
API_URL="https://api.z.ai/api/coding/paas/v4"
MODEL="glm-4.7"
TEMPERATURE=0.6
MAX_TOKENS=131072

# Check API key
if [ -z "$ZAI_API_KEY" ]; then
    echo "Error: ZAI_API_KEY environment variable not set"
    echo "Run: export ZAI_API_KEY=your_api_key_here"
    exit 1
fi

# Function to call GLM API
call_glm() {
    local prompt="$1"
    local context="$2"

    curl -s -X POST "$API_URL/chat/completions" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $ZAI_API_KEY" \
        -d "{
            \"model\": \"$MODEL\",
            \"messages\": [
                {
                    \"role\": \"system\",
                    \"content\": \"You are GLM, a large language model trained by Z.AI. You are helping with AIOS development tasks.\"
                },
                {
                    \"role\": \"user\",
                    \"content\": \"Context: $context\n\nTask: $prompt\"
                }
            ],
            \"temperature\": $TEMPERATURE,
            \"max_tokens\": $MAX_TOKENS,
            \"stream\": false
        }" | jq -r '.choices[0].message.content'
}

# Main execution
case "$1" in
    "analyze")
        # Code analysis task
        shift
        code_file="$1"
        if [ -f "$code_file" ]; then
            context=$(cat "$code_file")
            call_glm "Analyze this code for AIOS architecture compliance and suggest improvements:" "$context"
        else
            echo "Error: Code file $code_file not found"
        fi
        ;;
    "generate")
        # Code generation task
        shift
        prompt="$@"
        call_glm "Generate code for this task:" "$prompt"
        ;;
    "review")
        # Code review task
        shift
        code_file="$1"
        if [ -f "$code_file" ]; then
            context=$(cat "$code_file")
            call_glm "Review this code for quality, security, and performance:" "$context"
        else
            echo "Error: Code file $code_file not found"
        fi
        ;;
    *)
        echo "Usage: glm-zai-command {analyze|generate|review} [arguments]"
        echo ""
        echo "Commands:"
        echo "  analyze <code_file>    - Analyze code for AIOS compliance"
        echo "  generate <prompt>      - Generate code from prompt"
        echo "  review <code_file>     - Review code quality"
        echo ""
        echo "Environment variables:"
        echo "  ZAI_API_KEY             - Your Z.AI API key (required)"
        exit 1
        ;;
esac